---
import About from "../components/about-us/about.astro";
import Banner from "../components/banner/banner.astro";
import Education from "../components/education/education.astro";
import Navbar from "../components/navbar/Navbar.astro";
import Stack from "../components/stack/stack.astro";
import Projects from "../components/projects/projects.astro";

import "../index.css";
import "../reset.css";
import Contact from "../components/contact/contact.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Portafolio profesional de Lainer Cáceres Salas, desarrollador web especializado en front-end"
    />
    <title>Portafolio</title>
  </head>
  <body>
    <main class="main-container">
      <Navbar />
      <Banner />
      <About id="about" />
      <Projects id="projects" />
      <Stack id="stack" />
      <Education id="education" />
      <Contact />
    </main>
  </body>
</html>
