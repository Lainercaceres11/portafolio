---
import { Icon } from "astro-icon/components";
import "./projects.css";

const { id } = Astro.props;
---

<section class="projects" id={id}>
  <span class="u-subtitle">Proyectos</span>
  <h2 class="u-title">Trabajos recientes</h2>
  <div class="projects-card__container">
    <article class="projects-card">
      <h3>Teslo Shop</h3>
      <p>
        Una tienda online de productos con funcionalidades de carrito de
        compras, autentificación, ordenes y gestión de productos.
      </p>
      <div class="project-stack">
        <ul>
          <li>Next JS</li>
          <li>Next Auth</li>
          <li>Typescript</li>
          <li>Tailwind CSS</li>
          <li>Cloudinary</li>
          <li>Swiper</li>
          <li>PostgreSQL</li>
          <li>Prisma</li>
        </ul>

        <div class="project-link">
          <a
            href="https://teslo-shop-next-inky.vercel.app/"
            target="_blank"
            rel="noopener noreferrer"
            class="project-link__demo"
          >
            <div class="project-link_code">
              <Icon name="view" size={24} />
              <span>Demo</span>
            </div></a
          >
          <a
            href="https://github.com/Lainercaceres11/teslo-shop-next"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="project-link_code">
              <Icon name="github" size={24} />
              <span>Código</span>
            </div>
          </a>
        </div>
      </div>
    </article>

    <article class="projects-card">
      <h3>IMDB Clone</h3>
      <p>
        Clon de la interfaz de IMDB con funcionalidades de búsqueda,
        visualización de películas, autentificación y gestión de favoritos.
      </p>
      <div class="project-stack">
        <ul>
          <li>Next JS</li>
          <li>MongoDB</li>
          <li>Typescript</li>
          <li>Tailwind CSS</li>
          <li>Clerk Auth</li>
        </ul>

        <div class="project-link">
          <a
            href="https://imdb-clone-nine-lake.vercel.app/"
            target="_blank"
            rel="noopener noreferrer"
            class="project-link__demo"
          >
            <div class="project-link_code">
              <Icon name="view" size={24} />
              <span>Demo</span>
            </div></a
          >
          <a
            href="https://github.com/Lainercaceres11/imdb-clone"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="project-link_code">
              <Icon name="github" size={24} />
              <span>Código</span>
            </div>
          </a>
        </div>
      </div>
    </article>

    <article class="projects-card">
      <h3>Travel APP</h3>
      <p>
        Una plataforma para crear, planificar y organizar viajes personalizados
        con recomendaciones de destinos, itinerarios y gestión de reservas.
      </p>
      <div class="project-stack">
        <ul>
          <li>Next JS</li>
          <li>Next Auth</li>
          <li>Tailwind CSS</li>
          <li>React Leaflet</li>
          <li>Typescript</li>
          <li>Uploadthing</li>
          <li>PostgreSQL</li>
          <li>Prisma</li>
        </ul>

        <div class="project-link">
          <a
            href="https://travel-app-ten-sage.vercel.app/"
            target="_blank"
            rel="noopener noreferrer"
            class="project-link__demo"
          >
            <div class="project-link_code">
              <Icon name="view" size={24} />
              <span>Demo</span>
            </div></a
          >
          <a
            href="https://github.com/Lainercaceres11/travel-app"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="project-link_code">
              <Icon name="github" size={24} />
              <span>Código</span>
            </div>
          </a>
        </div>
      </div>
    </article>

    <article class="projects-card">
      <h3>Coin Gecko</h3>
      <p>
        Aplicación de seguimiento de precios de criptomonedas con datos en
        tiempo real, busqueda de monedas y gráficos interactivos.
      </p>
      <div class="project-stack">
        <ul>
          <li>Angular</li>
          <li>Typescript</li>
          <li>Rxjs</li>
          <li>Bootstrap</li>
        </ul>

        <div class="project-link">
          <a
            href="https://coin-gecko-precios-angular.vercel.app/"
            target="_blank"
            rel="noopener noreferrer"
            class="project-link__demo"
          >
            <div class="project-link_code">
              <Icon name="view" size={24} />
              <span>Demo</span>
            </div></a
          >
          <a
            href="https://github.com/Lainercaceres11/coinGecko-precios-angular"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="project-link_code">
              <Icon name="github" size={24} />
              <span>Código</span>
            </div>
          </a>
        </div>
      </div>
    </article>

    <article class="projects-card">
      <h3>Weather API</h3>
      <p>
        Aplicación para obtener y mostrar información del clima en tiempo real
        con pronósticos y alertas personalizadas.
      </p>
      <div class="project-stack">
        <ul>
          <li>React</li>
          <li>Typescript</li>
          <li>Tailwind CSS</li>
          <li>Vite</li>
        </ul>

        <div class="project-link">
          <a
            href="https://app-clima-react-ts.netlify.app/"
            target="_blank"
            rel="noopener noreferrer"
            class="project-link__demo"
          >
            <div class="project-link_code">
              <Icon name="view" size={24} />
              <span>Demo</span>
            </div></a
          >
          <a
            href="https://github.com/Lainercaceres11/app-clima-react"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="project-link_code">
              <Icon name="github" size={24} />
              <span>Código</span>
            </div>
          </a>
        </div>
      </div>
    </article>
  </div>
</section>
